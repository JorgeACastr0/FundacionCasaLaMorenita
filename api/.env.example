# ── Servidor ──────────────────────────────
PORT=3000
HOST=127.0.0.1
NODE_ENV=production

# ── Seguridad ─────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiar-por-una-clave-segura-larga

# Dominio del sitio (para CORS)
ALLOWED_ORIGIN=https://tudominio.com

# ── Redes Sociales (opcional) ─────────────
# Si no tienes token, el feed simplemente no se sincroniza.
# Obtener en: https://developers.facebook.com/
FB_PAGE_TOKEN=
FB_PAGE_ID=
